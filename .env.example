# Required — your Anthropic API key from console.anthropic.com → API Keys
# Paste it after the "=" with no quotes and no spaces.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — Google Sheets / Search Console (sync-sheet.js, spell-check-agent.js --sheet)
# Path to your service-account key file. Not needed for the daily-briefing demo.
GOOGLE_CREDENTIALS=./credentials.json

# Optional — Ahrefs data (hosting-seo-agent-system.js, content-pipeline.js)
# Agents degrade gracefully without it.
AHREFS_API_KEY=your_ahrefs_api_key_here
